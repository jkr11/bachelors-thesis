@article{zapletalErrortolerantQuantumConvolutional2024,
  title = {Error-Tolerant Quantum Convolutional Neural Networks for Symmetry-Protected Topological Phases},
  author = {Zapletal, Petr and McMahon, Nathan A. and Hartmann, Michael J.},
  date = {2024-07-26},
  journaltitle = {Physical Review Research},
  shortjournal = {Phys. Rev. Res.},
  volume = {6},
  number = {3},
