  shorttitle = {Matrix Product Operators for Symmetry-Protected Topological Phases},
  author = {Williamson, Dominic J. and Bultinck, Nick and Mariën, Michael and Sahinoglu, Mehmet B. and Haegeman, Jutho and Verstraete, Frank},
  date = {2016-11-30},
