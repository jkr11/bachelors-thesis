@online{santraQuantumResourcesQuantum2025,
  type = {Dissertation},
  title = {Quantum Resources in Quantum Technologies: {{From}} Quantum Optimization to Many-Body Physics},
  shorttitle = {Quantum Resources in Quantum Technologies},
  author = {Santra, Gopal Chandra},
  date = {2025},
