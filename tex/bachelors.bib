@article{weichselbaumNonabelianSymmetriesTensor2012,
  title = {Non-Abelian Symmetries in Tensor Networks: {{A}} Quantum Symmetry Space Approach},
  shorttitle = {Non-Abelian Symmetries in Tensor Networks},
  author = {Weichselbaum, Andreas},
  date = {2012-12-01},
  journaltitle = {Annals of Physics},
